{
  "name": "三重県釣りMAP",
  "short_name": "三重県釣りMAP",
  "description": "三重県の釣り場、漁港、港、マリーナをGPS付き地図で確認するアプリ",
  "id": "./",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "prefer_related_applications": false,
  "categories": [
    "navigation",
    "sports"
  ],
  "theme_color": "#050706",
  "background_color": "#000000",
  "orientation": "any",
  "icons": [
    {
      "src": "icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ]
}
